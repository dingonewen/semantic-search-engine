# Copy this file to .env and fill in your keys. Never commit .env.

# Required when LLM_PROVIDER=claude (default)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required when LLM_PROVIDER=gemini
GOOGLE_API_KEY=your_google_api_key_here

# Optional overrides
# LLM_PROVIDER=claude        # "claude" or "gemini"
# SEARCH_ROOT=test_tree      # root directory for document indexing
